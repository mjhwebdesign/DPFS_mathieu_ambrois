                            </div>
                        </div>
                        <div id="cart-resume-price" class="col-lg-4 mb-3">
                            <div class="resume sticky-top" aria-label="Order summary">
                                <div class="card__head">
                                    <div>
                                        <h2 class="card__title">Resumen</h2>
                                        <p class="card__sub muted">Subtotal, envio, y total</p>
                                    </div>
                                </div>
                                <div class="summaryRows">
                                    <div class="row">
                                        <span class="muted">Subtotal</span>
                                        <strong id="subtotalText">$ <%= subtotal.toFixed(2) %></strong>
                                    </div>
                                    <div class="row">
                                        <span class="muted">Envio</span>
                                        <% let shipping=subtotal * 0.05; let total=subtotal + shipping; %>
                                            <strong id="taxText">$ <%= shipping.toFixed(2) %></strong>
                                    </div>
                                    <hr>
                                    <div class="row row--total">
                                        <span>Total</span>
                                        <strong id="totalText">$ <%= total.toFixed(2) %></strong>
                                    </div>
                                </div>
                                <form class="text-end ms-4">
                                    <button type="submit" aria-label="Eikon - Ir al Pago"
                                        class="w-100 btn btn-sm eikon-btn">
                                        PAGAR

        <%- include('../partials/header') %>
            <section id="cart-detail">
                <div class="container">
                    <div class="row">
                        <div class="col-12 topbar">
                            <div class="cart-header">
                                <div class="cart-header-logo" aria-hidden="true">
                                    <i class="fa-solid fa-bag-shopping"></i>
                                </div>
                                <div class="cart-header-text">
                                    <h1>Carrito</h1>
                                    <p class="muted">Su compra en la tienda Eikon</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-lg-8 mb-3">
                            <div class="cart-resume-list">
                                <div class="card__head">
                                    <div>
                                        <h2 class="card__title">Articulos</h2>
                                        <p class="card__sub muted">Ajuste la cantidad y revisa las opciones</p>
                                    </div>
                                    <div class="pill" id="itemsCountPill" aria-live="polite">
                                        <i class="fa-solid fa-cart-shopping"></i>
                                        <span><span id="itemsCount">
                                                <%= cartCount %>
                                            </span> articulos</span>
                                    </div>
                                </div>
                                <% let subtotal=0; %>

                                    <% cart.forEach(product=> {
                                        subtotal += product.price * product.quantity;
                                        %>

                                        <div class="item">
                                            <a href="products/<%= product.id %>" class="cart-item-img">
                                                <div class="item__img">
                                                    <img src="<%= product.image %>" alt=" <%= product.title %>">
                                                </div>
                                            </a>
                                            <div class="item__title">
                                                <div>
                                                    <p class="item__name">
                                                        <%= product.title %>
                                                    </p>
                                                </div>
                                                <span class="badge" title="Unit price">
                                                    <i class="fa-solid fa-tag"></i>
                                                    <span>$ <%= product.price %></span>
                                                </span>
                                            </div>

                                            <div class="item__controls">
                                                <div class="price">$<%= (product.price * product.quantity).toFixed(2) %>
                                                </div>

                                                <div class="col-12 col-md-10 justify-content-start">
                                                    <div class="qty">

                                                        <button type="button" class="counter-btn qtyDec"
                                                            data-id="<%= product.id %>">-</button>

                                                        <div class="qtyVal">
                                                            <%= product.quantity %>
                                                        </div>

                                                        <button type="button" class="counter-btn qtyInc"
                                                            data-id="<%= product.id %>">+</button>
                                                    </div>
                                                </div>
                                                <button type="button" class="badge remove remove-btn"
                                                    data-id="<%= product.id %>">
                                                    <i class="fa fa-trash" aria-hidden="true"></i>
                                                    <span>Suprimir</span>
                                                </button>

                                            </div>
                                        </div>

                                        <% }) %>

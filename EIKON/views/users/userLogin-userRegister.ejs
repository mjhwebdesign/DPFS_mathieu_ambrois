<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head', { pageTitle: "Eikon | Login - Registro" }) %>
    <script>
        const formType = "<%= formType || 'login' %>";
    </script>

    <body>
        <!-- Page content-->
        <section>
            <div class="container-fluid">
                <div id="pink-bg" class="row pink-bg align-items-center">
                    <div id="welcome" class="col-md-5 offset-md-1 text-center text-md-start welcome will_animate">
                        <h1>WELCOME!</h1>
                    </div>
                    <div id="welcomeBack" class="col-md-5 text-center text-md-end welcomeBack will_animate">
                        <h1>WELCOME <br>BACK!</h1>
                    </div>
                </div>
                <div id="forms" class="row forms-content align-items-center">
                    <div class="col-md-5 offset-md-1 text-center text-md-start">
                        <form id="login" action="/users/login" method="POST" enctype="multipart/form-data" novalidate>
                            <div class="row log-in-content">
                                <div class="col-sm-12 form-group will_animate to-left">
                                    <input type="email" class="form-control" name="email" id="email-login"
                                        placeholder="Enter your email." required>
                                </div>
                                <div class="col-sm-12 form-group will_animate to-left">
                                    <input type="Password" name="password" class="form-control" id="password-login"
                                        placeholder="Enter your password." required>
                                </div>
                                <div class="col-sm-12 form-group invalid-feedback d-block  will_animate to-left">
                                    * No ingresaste un email valido
                                </div>
                                <div class="col-sm-12 form-group will_animate to-left">
                                    <input type="checkbox" name="remember" value="true"> <span
                                        class="reminderLinks">Recordarme</span>
                                </div>
                                <div class="col-sm-12 form-group mb-0 will_animate to-left">
                                    <button type="submit" id="submit-log-in" class="btn btn-primary float-right"
                                        name="submit-log-in">Submit</button>
                                </div>

                                <p id="signInLink" class="pt-3 will_animate to-left">Not Registered?
                                    <a href="#">Create
                                        an
                                        account</a>
                                </p>
                                <p id="reminderLinks" class="pt-3 will_animate to-left">
                                    <a href="#">
                                        Olvide mi contraseña
                                    </a> | <a href="/#products">
                                        Prefiero volver a la tienda
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                    <!-- -->
                    <div class="col-md-5 text-center text-md-end">

                        <form id="register" action="/users/create" method="POST" enctype="multipart/form-data"
                            novalidate>
                            <div class="row log-in-content">
                                <div class="col-sm-6 form-group will_animate to-right">
                                    <input type="text" class="form-control <%= errors?.firstName ? 'is-invalid' : '' %>"
                                        name="firstName" id="name-f" placeholder="Apellido."
                                        value="<%= oldData?.firstName || '' %>">
                                    <% if (errors?.firstName) { %>
                                        <div class="invalid-feedback d-block">
                                            <%= errors.firstName.msg %>
                                        </div>
                                        <% } %>
                                </div>
                                <div class="col-sm-6 form-group will_animate to-right">
                                    <input type="text" class="form-control <%= errors?.lastName ? 'is-invalid' : '' %>"
                                        name="lastName" id="name-l" placeholder="Nombre."
                                        value="<%= oldData?.lastName || '' %>">
                                    <% if (errors?.lastName) { %>
                                        <div class="invalid-feedback d-block">
                                            <%= errors.lastName.msg %>
                                        </div>
                                        <% } %>
                                </div>

                                <div class="col-sm-12 form-group will_animate to-right">
                                    <input type="email" name="email"
                                        class="form-control <%= errors?.email ? 'is-invalid' : '' %>" id="email"
                                        placeholder="Correo Electronico." value="<%= oldData?.email || '' %>">
                                    <% if (errors?.email) { %>
                                        <div class="invalid-feedback d-block">
                                            <%= errors.email.msg %>
                                        </div>
                                        <% } %>
                                </div>
                                <div class="col-sm-6 form-group will_animate to-right">
                                    <input type="Password" name="password"
                                        class="form-control <%= errors?.password ? 'is-invalid' : '' %>"
                                        id="passwordRegister" placeholder="Clave.">
                                    <% if (errors?.password) { %>
                                        <div class="invalid-feedback d-block">
                                            <%= errors.password.msg %>
                                        </div>
                                        <% } %>
                                </div>
                                <div class="col-sm-6 form-group will_animate to-right">
                                    <input type="Password" name="cnf-password" class="form-control" id="pass2"
                                        placeholder="Confirmar la clave.">
                                </div>

                                <div class="col-sm-12 form-group will_animate to-right">
                                    <label for="avatar" class="form-label custom-file-upload">Avatar:</label>
                                    <span id="avatar-file-name">Ningúna imagen seleccionada</span>
                                    <input class="form-control product-images <%= errors?.avatar ? 'is-invalid' : '' %>"
                                        type="file" accept="image/png, image/jpeg, image/jpg, image/gif, image/webp"
                                        id="avatar" name="avatar">
                                    <% if (errors?.avatar) { %>
                                        <div class="invalid-feedback d-block">
                                            <%= errors.avatar.msg %>
                                        </div>
                                        <% } %>
                                </div>
                                <div class="col-sm-12 form-group mb-0 will_animate to-right">
                                    <button id="submit-sign-in" class="btn btn-primary float-right"
                                        name="submit-register">Submit</button>
                                </div>
                                <p id="logInLink" class="pt-3 will_animate to-right">Already
                                    Registered? <a href="#">Log-In</a> <br><br> <a href="/#products">
                                        Prefiero volver a la tienda
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
        <!-- SCRIPTS -->
        <%- include('../partials/scripts') %>
    </body>

</html>